        <textarea name="mensagem" placeholder="Conte o que você quer na viagem"></textarea>

        <button type="submit">Solicitar roteiro</button>
    </form>
</section>

<footer>
    <p>© Fjord Dreams - Viagens Premium na Noruega</p>
</footer>

